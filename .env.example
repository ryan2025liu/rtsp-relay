# Copy to .env (do not commit secrets).
# Used with: docker-compose.yml (+ optional docker-compose.streams.yml).

RTSP_RELAY_IMAGE=skybrain/rtsp-relay:local

# Shared RTMP app path (no trailing stream name).
# Point this to your SRS server.
RTMP_RELAY_RTMP_BASE=rtmp://your-srs-host:1935/live

# H.265/HEVC cameras: set 1 so SRS HTTP-FLV + flv.js work (otherwise SRS may "drop unknown header video")
TRANSCODE_H264=1

# Optional ffmpeg defaults
# FFMPEG_LOGLEVEL=info
# FFMPEG_EXTRA_ARGS=

# ---------- Instance 01 (defined in docker-compose.yml) ----------
RTSP_RELAY_01_CONTAINER_NAME=skybrain-rtsp-relay-01
RTSP_RELAY_01_STREAM_ID=cam-gate-01
RTSP_RELAY_01_RTSP_URL=rtsp://user:pass@192.0.2.10:554/stream1
# Optional: full RTMP URL (overrides RTMP_BASE + STREAM_ID)
# RTSP_RELAY_01_RTMP_OUT=rtmp://your-srs-host:1935/live/cam-gate-01

# ---------- Instance 02 (after copying docker-compose.streams.example.yml to docker-compose.streams.yml) ----------
# RTSP_RELAY_02_CONTAINER_NAME=skybrain-rtsp-relay-02
# RTSP_RELAY_02_STREAM_ID=cam-yard-02
# RTSP_RELAY_02_RTSP_URL=rtsp://user:pass@192.0.2.11:554/h264
