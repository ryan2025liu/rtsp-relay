# 复制为 deploy/.env.server（勿提交含密码的目录；可选放到服务器家目录外并 chmod 600）
# 用法: docker compose -f docker-compose.server.yml --env-file deploy/.env.server up -d --build

# ---------- 与 SRS 同机 (192.168.107.230) 时推荐 ----------
# 用局域网 IP 推流，使 relay-api 容器能到达宿主机上的 SRS
DEFAULT_RTMP_BASE_URL=rtmp://192.168.107.230:1935/live

# 浏览器访问的 API 根（无尾部斜杠）；与对外映射一致
# 例: 仅内网时 http://192.168.107.230:18081
VITE_API_BASE_URL=http://192.168.107.230:18081

# 允许的前端来源（CORS），需包含管理页在浏览器中的 origin（与 RELAY_WEB_PORT 一致）
# 默认 18088，刻意避开 8080（多机器上已占给 SRS/其它服务）
RELAY_WEB_ALLOWED_ORIGINS=http://192.168.107.230:18088,http://127.0.0.1:18088

# ---------- 对外端口（与 SRS 的 1935/8080 等错开，防火墙同步放行） ----------
RELAY_API_PORT=18081
RELAY_WEB_PORT=18088

# ---------- 可选: 数据落盘到固定路径（默认相对部署目录下 ./runtime/...）----------
# RELAY_HOST_DATA_DIR=/var/lib/skybrain-relay/data
# RELAY_HOST_LOG_DIR=/var/log/skybrain-relay
# RELAY_HOST_TMP_DIR=/var/tmp/skybrain-relay
